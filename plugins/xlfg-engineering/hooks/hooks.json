{
  "description": "Lean automation for xlfg: skip the extra approval when Claude exits plan mode, block the conductor from ending before all phases complete, and block xlfg subagents from stopping before their required artifact exists.",
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PermissionRequest\", \"decision\": {\"behavior\": \"allow\"}}}'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/phase_gate.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "^xlfg-",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/subagent_stop_guard.py\""
          }
        ]
      }
    ]
  }
}
