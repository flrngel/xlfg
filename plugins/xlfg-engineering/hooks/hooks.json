{
  "description": "Lean automation for xlfg: skip the extra approval when Claude exits plan mode, and block xlfg subagents from stopping before their required artifact exists.",
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PermissionRequest\", \"decision\": {\"behavior\": \"allow\"}}}'"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "^xlfg-",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/subagent-stop-guard.mjs\""
          }
        ]
      }
    ]
  }
}
